ODDS_API_KEY=

# OddsPapi $49/mo: https://oddspapi.io/
# → Unlocks full cross-venue arb layer (Gate 4 Mode A)
# → Kalshi + Polymarket + 300 books in ONE call
ODDSPAPI_KEY=

# Polygon.io $29/mo: https://polygon.io/
# → Real-time WebSocket for EconomicsBot (futures) + CryptoBot
POLYGON_API_KEY=

# MySportsFeeds $9/mo: https://mysportsfeeds.com/
# → Advanced sports stats, injury reports, win rates
MYSPORTSFEEDS_KEY=

# Financial Modeling Prep $14/mo: https://financialmodelingprep.com/
# → Insider trading data + 30yr earnings history for TechBot
FMP_API_KEY=

# ── TIER 3 — PREMIUM (add once Tier 2 is profitable) ─────

# Glassnode $29/mo: https://glassnode.com/
# → On-chain exchange flows + whale counts for CryptoBot
GLASSNODE_API_KEY=

# Tomorrow.io (free/paid): https://tomorrow.io/
# → Hyperlocal weather with confidence intervals for WeatherBot
TOMORROW_IO_KEY=

# Alpha Vantage $50/mo: https://alphavantage.co/
# → News sentiment scoring for EconomicsBot + TechBot
ALPHA_VANTAGE_KEY=

# Coinglass $49/mo: https://coinglass.com/
# → Funding rates + liquidation heatmaps for CryptoBot
COINGLASS_KEY=

# Lunarcrush $49/mo: https://lunarcrush.com/
